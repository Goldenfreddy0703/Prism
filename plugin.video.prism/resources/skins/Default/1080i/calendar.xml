                            <width>50</width>
                            <height>25</height>
                            <font>font12</font>
                            <textcolor>AAFFFFFF</textcolor>
                            <align>center</align>
                            <label>$INFO[ListItem.Property(rating_imdb)]</label>
                        </control>
